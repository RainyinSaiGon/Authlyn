# --- Application ---
SERVER_PORT=8080

# --- PostgreSQL (Neon is mandatory for all developers) ---
AUTHLYN_DB_NAME=neondb
AUTHLYN_DB_URL=jdbc:postgresql://<your-neon-host>:5432/neondb?sslmode=require
AUTHLYN_DB_USERNAME=<your-neon-username>
AUTHLYN_DB_PASSWORD=<your-neon-password>

# --- Redis (local Docker) ---
AUTHLYN_REDIS_HOST=localhost
AUTHLYN_REDIS_PORT=6379
AUTHLYN_REDIS_PASSWORD=

# --- Security baseline ---
AUTHLYN_BCRYPT_STRENGTH=12

# --- Mail ---
AUTHLYN_MAIL_HOST=localhost
AUTHLYN_MAIL_PORT=1025
AUTHLYN_MAIL_USERNAME=
AUTHLYN_MAIL_PASSWORD=
AUTHLYN_MAIL_SMTP_AUTH=false
AUTHLYN_MAIL_STARTTLS=false

# --- Feature flags / platform ---
AUTHLYN_FEATURE_FLAG_SOURCE=local
AUTHLYN_TRUSTED_PROXY_CIDRS=
AUTHLYN_ALLOWED_ORIGINS=http://localhost:5173
